{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["src/webview/**/*.tsx", "src/webview/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
